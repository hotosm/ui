{
  "name": "@hotosm/ui",
  "version": "0.1.0",
  "description": "Shared UI components with theming for use across HOTOSM tools.",
  "type": "module",
  "main": "./dist/hotui.umd.cjs",
  "module": "./dist/hotui.js",
  "types": "./dist/index.d.ts",
  ".": {
    "import": "./dist/hotui.js",
    "require": "./dist/hotui.umd.cjs"
  },
  "./dist/": {
    "import": "./dist/",
    "require": "./dist/"
  },
  "engines": {
    "node": ">=14.17"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint --ext .js,.ts ./",
    "dev": "storybook dev -p 3001",
    "dev:react": "storybook dev -c .storybook-react -p 3002",
    "build": "tsc && vite build",
    "build:react": "tsc && vite build -c vite-react.config.ts",
    "build:docstrings": "wca analyze 'src/**/*.{js,ts}' --outDir 'docs/components' --format 'markdown'",
    "build:stories": "storybook build --output-dir=docs/stories",
    "build:docs": "pnpm run build:docstrings && pnpm run build:stories",
    "prepare": "run-s build:react"
  },
  "keywords": [],
  "author": {
    "name": "HOTOSM",
    "email": "sysadmin@hotosm.org"
  },
  "contributors": [
    {
      "name": "Joe",
      "url": "https://github.com/joltcode"
    },
    {
      "name": "Emi Mariscal",
      "url": "https://github.com/emi420"
    },
    {
      "name": "Deepak Pradhan",
      "url": "https://github.com/varun2948"
    },
    {
      "name": "Sam Woodcock",
      "url": "https://github.com/spwoodcock"
    }
  ],
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@lit/react": "^1.0.3",
    "@storybook/addon-essentials": "^7.6.5",
    "@storybook/addon-links": "^7.6.5",
    "@storybook/blocks": "^7.6.5",
    "@storybook/react": "^7.6.15",
    "@storybook/react-vite": "^7.6.15",
    "@storybook/web-components": "^7.6.5",
    "@storybook/web-components-vite": "^7.6.5",
    "@types/node": "^20.11.17",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@unocss/postcss": "^0.58.5",
    "autoprefixer": "^10.4.16",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-standard-with-typescript": "^43.0.0",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-lit": "^1.10.1",
    "eslint-plugin-n": "^15.0.0 || ^16.0.0 ",
    "eslint-plugin-promise": "^6.0.0",
    "eslint-plugin-wc": "^2.0.4",
    "lit": "^3.1.0",
    "npm-run-all": "^4.1.5",
    "storybook": "^7.6.5",
    "tsup": "^7.2.0",
    "type-fest": "^4.8.3",
    "typescript": "^5.2.2",
    "unocss": "^0.58.0",
    "vite": "^5.0.7",
    "vite-plugin-dts": "^3.7.2",
    "vite-tsconfig-paths": "^4.2.2",
    "web-component-analyzer": "^2.0.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hotosm/ui.git"
  },
  "bugs": {
    "url": "https://github.com/hotosm/ui/issues"
  },
  "homepage": "https://github.com/hotosm/ui#readme",
  "dependencies": {
    "postcss-cli": "^11.0.0"
  },
  "peerDependencies": {
    "react": "^17.0.2 || ^18.2.0",
    "react-dom": "^17.0.2 || ^18.2.0"
  }
}
